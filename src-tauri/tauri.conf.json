{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BOBOTexture V2",
  "version": "0.1.0",
  "identifier": "com.bobotexture.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BOBOTexture V2",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "transparent": false,
        "decorations": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": false,
    "category": "Utility"
  }
}
